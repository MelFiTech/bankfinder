generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ResolvedAccount {
  id            String   @id @default(cuid())
  accountNumber String   @unique
  accountName   String
  bankCode      String
  bankName      String
  resolvedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountNumber])
}
